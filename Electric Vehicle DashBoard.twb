      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.1lwhfn50xj31sc145qq3x0dmc0c0].[pcto:usr:Calculation_0135836739756032:qk]&quot;' value='% of Total Total ' />
        </aliases>
      </column>
      <column caption='Total Vehicles' datatype='integer' name='[Calculation_0135836739756032]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='count([DOL Vehicle ID])' />
      </column>
      <column caption='Average Electric Range' datatype='real' name='[Calculation_0135836740599809]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='avg([Electric Range])' />
      </column>
      <column caption='Total BEV Vehicles' datatype='integer' name='[Calculation_0135836741787650]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='countd(&#13;&#10;if [Electric Vehicle Type]=&apos;Battery Electric Vehicle (BEV)&apos;&#13;&#10;then [DOL Vehicle ID] end)' />
      </column>
      <column caption='% of BEV Vehicles' datatype='real' name='[Calculation_0135836743081987]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0135836741787650]/[Calculation_0135836739756032]' />
      </column>
      <column caption='Total PHEV Vehicles' datatype='integer' name='[Calculation_0135836743651332]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='countd(if [Electric Vehicle Type]=&apos;Plug-in Hybrid Electric Vehicle (PHEV)&apos;&#13;&#10;then [DOL Vehicle ID] end)' />
      </column>
      <column caption='% of PHEV Vehicles' datatype='real' name='[Calculation_0135836743946245]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0135836743651332]/[Calculation_0135836739756032]' />
